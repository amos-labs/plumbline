{
  "name": "plumbline",
  "version": "0.2.3",
  "description": "Plumbline \u2014 the plumb line for AI agent work (Amos 7:7-8): structured proof receipts, deterministic shape checks, LLM semantic review, and failure-capsule rework loops.",
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "plumb": "dist/cli.js",
    "proofgate": "dist/cli.js"
  },
  "files": [
    "dist",
    "templates",
    "action.yml",
    "README.md",
    "LICENSE",
    "THIRD-PARTY.md"
  ],
  "scripts": {
    "build": "tsc",
    "bundle": "esbuild src/cli.ts --bundle --platform=node --target=node20 --format=esm --legal-comments=none --outfile=dist/index.js",
    "package": "npm run build && npm run bundle",
    "prepare": "tsc",
    "check": "tsc --noEmit",
    "test": "node --test dist/test/"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "esbuild": "^0.28.1",
    "typescript": "^5.5.0"
  }
}
